{
  "name": "qualJogador",
  "version": "1.0.0",
  "main": "index.js",
  "homepage": "https://mixurim.github.io/qualJogador/",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build": "npx expo export --platform web --output-dir dist",
    "predeploy": "node -e \"const fs=require('fs'); fs.copyFileSync('.nojekyll','dist/.nojekyll')\"",
    "deploy": "npm run build && npm run predeploy && gh-pages -d dist"
  },
  "dependencies": {
    "expo": "~54.0.34",
    "expo-router": "~6.0.24",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "^0.81.5",
    "react-native-web": "^0.21.0",
    "react-native-safe-area-context": "^5.4.1",
    "expo-linking": "^5.0.0"
  },
  "devDependencies": {
    "gh-pages": "^6.3.0"
  },
  "private": true
}
